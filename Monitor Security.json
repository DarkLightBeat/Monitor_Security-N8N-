    {
      "parameters": {
        "jsCode": "// Normalize Palo Alto RSS items to a common schema\nreturn $input.all().map(item => ({\n  json: {\n    title: item.json.title || '',\n    link: item.json.link || '',\n    pubDate: item.json.pubDate || new Date().toISOString(),\n    severity: item.json.title && item.json.title.includes('Severity:')\n      ? item.json.title.split('Severity:')[1].replace(')', '').trim()\n      : 'Unknown',\n    type: item.json.title ? item.json.title.split(':')[0].trim() : 'Palo Alto',\n    source: 'Palo Alto'\n  }\n}));"
      },
      "id": "b01f66ff-f3d9-483e-8db8-5e3ab4dff440",
      "name": "Normalize Palo Alto",
      "type": "n8n-nodes-base.code",
      "position": [
        -3664,
        96
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "// Split and normalize CISA KEV JSON feed into individual advisory items\nconst data = $input.first().json;\nconst vulns = (data.vulnerabilities || []).slice(0, 50);\nif (vulns.length === 0) return [];\nreturn vulns.map(v => ({\n  json: {\n    title: `${v.cveID}: ${v.vulnerabilityName} (Severity: High)`,\n    link: `https://www.cisa.gov/known-exploited-vulnerabilities-catalog`,\n    pubDate: v.dateAdded ? new Date(v.dateAdded + 'T00:00:00Z').toISOString() : new Date().toISOString(),\n    severity: 'High',\n    type: 'CISA KEV',\n    source: 'CISA KEV',\n    description: v.shortDescription || ''\n  }\n}));"
      },
      "id": "84549355-dca6-4efb-9f88-dcc00bba8df2",
      "name": "Normalize CISA",
      "type": "n8n-nodes-base.code",
      "position": [
        -3664,
        288
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "// Get all items that were automatically split by the HTTP Request node\nconst items = $input.all();\n\n// Map over each item to normalize it to your common schema\nreturn items.map(item => {\n  const a = item.json;\n  \n  // Guard clause: skip if it's an unexpected response (like an API error)\n  if (!a.ghsa_id) return null;\n\n  // Format the severity text\n  const sev = a.severity\n    ? a.severity.charAt(0).toUpperCase() + a.severity.slice(1)\n    : 'Unknown';\n    \n  return {\n    json: {\n      title: `${a.ghsa_id}: ${a.summary} (Severity: ${sev})`,\n      link: a.html_url || `https://github.com/advisories/${a.ghsa_id}`,\n      pubDate: a.published_at || new Date().toISOString(),\n      severity: sev,\n      type: 'GitHub Advisory',\n      source: 'GitHub',\n      description: a.description || ''\n    }\n  };\n}).filter(item => item !== null); // This removes any empty/null items"
      },
      "id": "360e0774-fb0e-4773-91f4-006486151eb8",
      "name": "Normalize GitHub",
      "type": "n8n-nodes-base.code",
      "position": [
        -3664,
        496
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "// Passthrough — all fields already normalized upstream.\n// Keeping this node named 'Extract info' so all downstream\n// expressions like $('Extract info').item.json.title continue to work\n// regardless of which source (Palo Alto / CISA / GitHub) the item came from.\nreturn $input.all().map(item => ({ json: item.json }));"
      },
