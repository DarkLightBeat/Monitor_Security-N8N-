        "jsCode": "const rawMessage = $input.first().json.chatInput\n\n// Convert string → JSON\nlet advisories;\n\ntry {\n  advisories = JSON.parse(rawMessage);\n} catch (e) {\n  throw new Error(\"Invalid JSON input in chat message\");\n}\n\nif (!Array.isArray(advisories)) return [];\n\nreturn advisories.map(a => ({\n  json: {\n      title: a.title || `${a.ghsa_id}: ${a.summary}`,\n      link: a.link || a.html_url,\n      pubDate: a.pubDate || a.published_at,\n      severity: a.severity,\n      type: a.type || \"Advisory\",\n      source: a.source || \"Unknown\",\n      description: a.description || \"\"\n    }\n}));"
