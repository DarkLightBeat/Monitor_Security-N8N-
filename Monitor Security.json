      "parameters": {
        "jsCode": "const newAdvisories = $('Check if posted in last 24 hours').all(0, 0);\n\nconst storedRecords = $input.all();\n\nconst storedTitles = storedRecords.map(item => item.json.title || item.json.Title).filter(Boolean);\n\nconst uniqueAdvisories = newAdvisories.filter(advisory => {\n  // If the storedTitles array does NOT contain this advisory's title, keep it!\n  return !storedTitles.includes(advisory.json.title);\n});\n\nreturn uniqueAdvisories;"
      },
